  "agents": {
    "claude": {
      "type": "Claude Code",
      "cli": "claude",
      "version": "2.1.63",
      "provider": "Anthropic",
      "models": {
        "claude-opus-4-6":   { "tier": "flagship", "cost_input": 15, "cost_output": 75, "context": "200K", "note": "Best reasoning, architecture, complex tasks" },
        "claude-sonnet-4-6": { "tier": "workhorse", "cost_input": 3, "cost_output": 15, "context": "200K", "note": "Default. Best balance of speed/quality" },

      },
      "default_model": "gemini-2.5-flash (enforced, Pro requires explicit -m flag)",
      "model_flag": "-m <model-id>",
      "free_tier": "60 req/min, 1000 req/day with Google account",
      "strengths": [
        "Fast codebase investigation and grep",
        "Bulk data analysis (CSV, DuckDB, large datasets)",
        "Report generation and documentation",
        "1M token context (entire repos)",
        "Schema dumps and auditing",
        "Dependency analysis and import mapping",
        "FREE tier for most work"
